---
import BaseLayout from './BaseLayout.astro';
import HeroVariant from '../components/HeroVariant.astro';
import CTABanner from '../components/CTABanner.astro';
import DevisCTA from '../components/DevisCTA.astro';
import TrustBadges from '../components/TrustBadges.astro';
import { getServiceSchema } from '../lib/seo';

interface Props {
  name: string;
  metaTitle: string;
  metaDescription: string;
  models: string[];
  warranty: string;
  breadcrumbs: { name: string; url: string }[];
}

const { name, metaTitle, metaDescription, models, warranty, breadcrumbs } = Astro.props;

const seo = { title: metaTitle, description: metaDescription };

const serviceSchema = getServiceSchema({
  name: `Installation climatisation ${name} à Colomiers`,
  description: metaDescription,
  url: new URL(Astro.url.pathname, Astro.site).href,
});
---

<BaseLayout seo={seo} schemas={[serviceSchema]}>
  <HeroVariant
    title={`Installateur ${name} à Colomiers`}
    subtitle={`Installation, entretien et dépannage de climatisation ${name}. Artisan certifié RGE QualiPAC.`}
    breadcrumbs={breadcrumbs}
  />

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <div class="flex justify-center mb-12">
        <TrustBadges />
      </div>

      <div class="max-w-prose mx-auto prose prose-slate prose-lg prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary-600">
        <slot />
      </div>

      {models.length > 0 && (
        <div class="mt-12 max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Modèles {name} que nous installons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {models.map((model) => (
              <div class="flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3">
                <svg class="w-4 h-4 text-primary-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-sm text-slate-700">{model}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {warranty && (
        <div class="mt-8 max-w-2xl mx-auto bg-trust-50 border border-trust-200 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-trust-700 mb-1">Garantie {name}</h3>
          <p class="text-slate-700">{warranty}</p>
        </div>
      )}

      <div class="max-w-prose mx-auto mt-12">
        <DevisCTA title={`Devis installation ${name}`} text={`Obtenez un devis gratuit pour l'installation de votre climatisation ${name}. Artisan RGE, aides MaPrimeRénov' possibles.`} />
      </div>
    </div>
  </section>

  <CTABanner title={`Installation ${name} à Colomiers et Toulouse`} />
</BaseLayout>
