---
import '../styles/global.css';
import { company } from '../data/company';
import { getLocalBusinessSchema } from '../lib/seo';
import type { SEOProps } from '../lib/seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

interface Props {
  seo: SEOProps;
  schemas?: Record<string, unknown>[];
}

const { seo, schemas = [] } = Astro.props;
const canonicalURL = seo.canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImage = seo.ogImage || `${company.site}/og-default.jpg`;
const ogType = seo.ogType || 'website';
const localBusinessSchema = getLocalBusinessSchema();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={company.name} />
    {seo.article && (
      <>
        <meta property="article:published_time" content={seo.article.publishedTime} />
        <meta property="article:modified_time" content={seo.article.modifiedTime} />
        <meta property="article:author" content={seo.article.author} />
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- LocalBusiness Schema (toutes les pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Schemas additionnels -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- GTM (remplacer par le vrai ID) -->
    <script is:inline>
      // Google Tag Manager — ne charge que si GTM_ID est configuré
      (function() {
        var gtmId = 'GTM-XXXXXXX'; // TODO: remplacer par import.meta.env.PUBLIC_GTM_ID
        if (gtmId && gtmId !== 'GTM-XXXXXXX') {
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',gtmId);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-white text-slate-700 antialiased">
    <a href="#main-content" class="skip-to-content">Aller au contenu principal</a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <StickyMobileCTA />
    <Footer />

    <!-- Tracking: phone clicks -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href^="tel:"]');
        if (link && window.dataLayer) {
          window.dataLayer.push({ event: 'phone_click', phone_number: link.href });
        }
      });
    </script>
  </body>
</html>
