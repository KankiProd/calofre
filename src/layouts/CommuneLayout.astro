---
import BaseLayout from './BaseLayout.astro';
import HeroVariant from '../components/HeroVariant.astro';
import TrustBadges from '../components/TrustBadges.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQ from '../components/FAQ.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import { getLocalBusinessSchema, getBreadcrumbSchema } from '../lib/seo';
import { company } from '../data/company';

interface Props {
  name: string;
  metaTitle: string;
  metaDescription: string;
  postalCode: string;
  responseTime: string;
  highlights: string[];
  breadcrumbs: { name: string; url: string }[];
}

const { name, metaTitle, metaDescription, postalCode, responseTime, highlights, breadcrumbs } = Astro.props;

const seo = {
  title: metaTitle,
  description: metaDescription,
};
---

<BaseLayout seo={seo}>
  <HeroVariant
    title={`Plombier Chauffagiste Climatiseur à ${name}`}
    subtitle={`CALOFRÉ intervient à ${name} (${postalCode}) en ${responseTime}. Certifié RGE QualiPAC. Devis gratuit sous 24h.`}
    breadcrumbs={breadcrumbs}
  />

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <div class="flex justify-center mb-12">
        <TrustBadges />
      </div>

      <div class="max-w-prose mx-auto prose prose-slate prose-lg prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary-600">
        <slot />
      </div>

      {highlights.length > 0 && (
        <div class="mt-12 max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Pourquoi choisir CALOFRÉ à {name} ?</h2>
          <ul class="space-y-3">
            {highlights.map((h) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-trust-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-slate-700">{h}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <ServicesGrid />

  <CTABanner title={`Besoin d'un artisan à ${name} ?`} subtitle={`Intervention en ${responseTime}. Devis gratuit et sans engagement.`} />
</BaseLayout>
