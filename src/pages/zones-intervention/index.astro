---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVariant from '../../components/HeroVariant.astro';
import CTABanner from '../../components/CTABanner.astro';
import { communes } from '../../data/communes';

const seo = {
  title: 'Zones d\'intervention — Colomiers, Toulouse | CALOFRÉ',
  description: 'CALOFRÉ intervient à Colomiers, Tournefeuille, Blagnac, Plaisance-du-Touch, Toulouse et dans toute la Haute-Garonne. Plomberie, chauffage, climatisation RGE.',
};

const breadcrumbs = [
  { name: 'Accueil', url: 'https://calofre.fr/' },
  { name: 'Zones d\'intervention', url: 'https://calofre.fr/zones-intervention/' },
];
---

<BaseLayout seo={seo}>
  <HeroVariant title="Zones d'intervention" subtitle="Basés à Colomiers, nous intervenons dans toute l'agglomération toulousaine pour vos besoins en plomberie, chauffage et climatisation." breadcrumbs={breadcrumbs} />

  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {communes.map((commune) => (
          <a href={`/zones-intervention/${commune.slug}/`} class="group block bg-white border border-slate-100 rounded-2xl p-6 shadow-soft hover:shadow-card-hover transform hover:-translate-y-1 transition-all duration-200">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center text-primary-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h2 class="text-lg font-semibold text-slate-900 group-hover:text-primary-700 transition-colors">{commune.name}</h2>
                <span class="text-sm text-slate-500">{commune.postalCode}</span>
              </div>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-slate-600">Intervention en {commune.responseTime}</span>
              {commune.distanceFromColomiers === 0 ? (
                <span class="inline-flex items-center bg-trust-50 text-trust-700 text-xs font-semibold px-2 py-0.5 rounded-full">Siège</span>
              ) : (
                <span class="text-slate-500">{commune.distanceFromColomiers} km</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner title="Votre commune n'est pas listée ?" subtitle="Contactez-nous, nous intervenons dans toute la Haute-Garonne." />
</BaseLayout>
