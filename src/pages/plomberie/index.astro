---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVariant from '../../components/HeroVariant.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import { getServiceSchema } from '../../lib/seo';

const seo = {
  title: 'Plombier à Colomiers — Dépannage & Travaux | CALOFRÉ',
  description: 'Plombier à Colomiers et Toulouse : dépannage urgence fuite, débouchage, rénovation salle de bain, ballon d\'eau chaude. Devis gratuit sous 24h. 4,9★ Google.',
};

const breadcrumbs = [
  { name: 'Accueil', url: 'https://calofre.fr/' },
  { name: 'Plomberie', url: 'https://calofre.fr/plomberie/' },
];

const serviceSchema = getServiceSchema({
  name: 'Plomberie — Dépannage et travaux',
  description: seo.description,
  url: 'https://calofre.fr/plomberie/',
});

const services = [
  {
    title: 'Dépannage urgence',
    description: 'Fuite d\'eau, dégât des eaux, WC bouché : intervention rapide 7j/7 sur Colomiers et agglomération toulousaine.',
    href: '/plomberie/depannage-urgence/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
  {
    title: 'Rénovation salle de bain',
    description: 'Rénovation complète ou partielle de votre salle de bain. Du plan à la réalisation, un seul interlocuteur.',
    href: '/plomberie/renovation-salle-de-bain/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  },
  {
    title: 'Fuite d\'eau',
    description: 'Recherche et réparation de fuite d\'eau apparente ou encastrée. Détection non destructive.',
    href: '/plomberie/fuite-eau/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>',
  },
  {
    title: 'Débouchage canalisation',
    description: 'Débouchage de canalisation, WC, évier, douche. Intervention rapide avec matériel professionnel.',
    href: '/plomberie/debouchage-canalisation/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>',
  },
  {
    title: 'Ballon d\'eau chaude',
    description: 'Installation, remplacement et dépannage de ballon d\'eau chaude électrique et thermodynamique.',
    href: '/plomberie/ballon-eau-chaude/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>',
  },
];

const faqs = [
  { question: 'Combien coûte un dépannage plomberie à Colomiers ?', answer: 'Le tarif dépend de la nature de l\'intervention. Un débouchage simple démarre autour de 80 à 150 €. Une réparation de fuite entre 100 et 300 €. Le devis est toujours gratuit et sans engagement.' },
  { question: 'Intervenez-vous en urgence le week-end ?', answer: 'Oui, nous proposons un service de dépannage urgence 7j/7 pour les fuites d\'eau, dégâts des eaux et pannes critiques sur Colomiers et les communes limitrophes.' },
  { question: 'Faites-vous la rénovation complète de salle de bain ?', answer: 'Oui, nous prenons en charge la rénovation complète : plomberie, pose de sanitaires, carrelage en partenariat avec nos artisans, et mise aux normes de l\'installation.' },
];
---

<BaseLayout seo={seo} schemas={[serviceSchema]}>
  <HeroVariant title="Plomberie à Colomiers et Toulouse" subtitle="Dépannage urgence 7j/7, rénovation salle de bain, réparation de fuite et débouchage. Artisan de confiance, devis gratuit." breadcrumbs={breadcrumbs} />

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <div class="flex justify-center mb-12">
        <TrustBadges />
      </div>

      <div class="max-w-prose mx-auto mb-16">
        <p class="text-lg text-slate-700 leading-relaxed">
          CALOFRÉ est votre plombier de proximité à Colomiers. Que ce soit pour une urgence (fuite, WC bouché, dégât des eaux) ou pour des travaux planifiés (rénovation salle de bain, remplacement de ballon d'eau chaude), notre équipe intervient rapidement avec un diagnostic transparent et un devis gratuit.
        </p>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">
          Noté 4,9/5 sur Google par nos clients, nous mettons un point d'honneur à la qualité du travail, la ponctualité et la clarté de nos tarifs. Pas de mauvaise surprise : le prix annoncé est le prix facturé.
        </p>
      </div>

      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 text-center mb-12">Nos prestations plomberie</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <CTABanner title="Une urgence plomberie ?" subtitle="Intervention rapide sur Colomiers et alentours. Appelez maintenant ou demandez un devis en ligne." />

  <FAQ items={faqs} />
</BaseLayout>
