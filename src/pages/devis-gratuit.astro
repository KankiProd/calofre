---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVariant from '../components/HeroVariant.astro';
import TrustBadges from '../components/TrustBadges.astro';
import { company } from '../data/company';

const seo = {
  title: 'Devis Gratuit — Plomberie Chauffage Climatisation | CALOFRÉ',
  description: 'Demandez un devis gratuit et sans engagement pour vos travaux de plomberie, chauffage ou climatisation à Colomiers et Toulouse. Réponse sous 24h.',
};

const breadcrumbs = [
  { name: 'Accueil', url: 'https://calofre.fr/' },
  { name: 'Devis gratuit', url: 'https://calofre.fr/devis-gratuit/' },
];
---

<BaseLayout seo={seo}>
  <HeroVariant title="Demander un devis gratuit" subtitle="Décrivez votre projet et recevez une estimation sous 24h. Sans engagement." breadcrumbs={breadcrumbs} />

  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Formulaire -->
        <div class="lg:col-span-3">
          <form id="devis-form" action="/api/devis/" method="POST" class="space-y-6">
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <label for="website">Ne pas remplir</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-slate-700 mb-1.5">Type de besoin *</label>
              <select id="service" name="service" required class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors">
                <option value="">Sélectionnez un service</option>
                <option value="Plomberie urgence">Plomberie — Dépannage urgence</option>
                <option value="Plomberie travaux">Plomberie — Travaux / rénovation</option>
                <option value="Chauffage">Chauffage (chaudière, PAC)</option>
                <option value="Climatisation">Climatisation</option>
                <option value="Entretien">Entretien annuel</option>
                <option value="Autre">Autre</option>
              </select>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Nom complet *</label>
                <input type="text" id="name" name="name" required minlength="2" class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" placeholder="Jean Dupont" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-1.5">Téléphone *</label>
                <input type="tel" id="phone" name="phone" required pattern="^(?:(?:\+|00)33|0)\s*[1-9](?:[\s.-]*\d{2}){4}$" class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" placeholder="06 12 34 56 78" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" placeholder="jean@exemple.fr" />
              </div>
              <div>
                <label for="postal" class="block text-sm font-medium text-slate-700 mb-1.5">Code postal *</label>
                <input type="text" id="postal" name="postal" required pattern="^\d{5}$" class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" placeholder="31770" />
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Décrivez votre projet</label>
              <textarea id="message" name="message" rows="4" class="w-full border border-slate-300 rounded-xl px-4 py-3 text-slate-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-y" placeholder="Décrivez votre besoin : type de travaux, surface, urgence..."></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 w-4 h-4 text-primary-600 border-slate-300 rounded focus:ring-primary-500" />
              <label for="rgpd" class="text-sm text-slate-600">
                J'accepte que mes données soient utilisées pour traiter ma demande de devis. Consultez notre <a href="/politique-confidentialite/" class="text-primary-600 hover:underline">politique de confidentialité</a>. *
              </label>
            </div>

            <button type="submit" class="w-full bg-primary-700 hover:bg-primary-800 text-white font-semibold py-3.5 rounded-xl hover:shadow-lg active:scale-[0.98] transition-all">
              Envoyer ma demande de devis
            </button>

            <div id="form-success" class="hidden bg-trust-50 border border-trust-200 text-trust-700 rounded-xl p-4 text-center font-medium">
              Votre demande a été envoyée ! Nous vous recontactons sous 24h.
            </div>
            <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 text-center">
              Une erreur est survenue. Appelez-nous directement au {company.phone.display}.
            </div>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2">
          <div class="sticky top-24 space-y-6">
            <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-4">Besoin d'une réponse rapide ?</h3>
              <a href={company.phone.href} class="flex items-center gap-3 bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 px-5 rounded-xl transition-colors mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Appeler le {company.phone.display}
              </a>
              <p class="text-sm text-slate-600">{company.openingHours.displayFR}</p>
            </div>

            <TrustBadges />

            <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6">
              <h3 class="text-lg font-semibold text-primary-900 mb-3">Ce que vous obtenez</h3>
              <ul class="space-y-2.5 text-sm text-primary-800">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Devis détaillé sous 24h
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Sans engagement, totalement gratuit
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Simulation aides MaPrimeRénov' incluse
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Tarif transparent, pas de surprise
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.getElementById('devis-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    var form = e.target;
    var data = new FormData(form);

    if (window.dataLayer) {
      window.dataLayer.push({ event: 'devis_submitted', service: data.get('service') });
    }

    fetch('/api/devis/', { method: 'POST', body: data })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) {
          form.style.display = 'none';
          document.getElementById('form-success').classList.remove('hidden');
        } else {
          document.getElementById('form-error').classList.remove('hidden');
        }
      })
      .catch(function() {
        document.getElementById('form-error').classList.remove('hidden');
      });
  });

  var firstInput = document.querySelector('#devis-form input, #devis-form select');
  if (firstInput) {
    firstInput.addEventListener('focus', function() {
      if (window.dataLayer) {
        window.dataLayer.push({ event: 'devis_started' });
      }
    }, { once: true });
  }
</script>
