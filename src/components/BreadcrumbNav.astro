---
import { getBreadcrumbSchema } from '../lib/seo';

interface Props {
  items: { name: string; url: string }[];
  variant?: 'default' | 'light';
}

const { items, variant = 'default' } = Astro.props;
const isLight = variant === 'light';
const schema = getBreadcrumbSchema(items);
---

<nav aria-label="Fil d'Ariane">
  <ol class={`flex flex-wrap items-center gap-1.5 text-sm ${isLight ? 'text-primary-200' : 'text-slate-500'}`}>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span class={isLight ? 'text-primary-400' : 'text-slate-400'} aria-hidden="true">&rsaquo;</span>}
        {i < items.length - 1 ? (
          <a
            href={item.url}
            class={`hover:underline ${isLight ? 'hover:text-white' : 'hover:text-primary-700'} transition-colors`}
          >
            {item.name}
          </a>
        ) : (
          <span class={isLight ? 'text-white font-medium' : 'text-slate-800 font-medium'} aria-current="page">
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
