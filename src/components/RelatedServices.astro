---
import ServiceCard from './ServiceCard.astro';

interface ServiceItem {
  title: string;
  description: string;
  href: string;
  icon: string;
}

interface Props {
  services: ServiceItem[];
  title?: string;
}

const { services, title = 'Services associés' } = Astro.props;
---

{services.length > 0 && (
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-8">{title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>
)}
