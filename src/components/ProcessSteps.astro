---
const steps = [
  {
    number: '01',
    title: 'Contactez-nous',
    description: 'Appelez-nous ou remplissez le formulaire de devis en ligne. Réponse garantie sous 24h.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  },
  {
    number: '02',
    title: 'Diagnostic gratuit',
    description: 'Un technicien se déplace pour évaluer votre besoin et vous propose un devis détaillé et transparent.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>',
  },
  {
    number: '03',
    title: 'Intervention',
    description: 'Nos techniciens certifiés RGE interviennent avec le matériel adapté, dans le respect des normes.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  },
  {
    number: '04',
    title: 'Suivi & garantie',
    description: 'Vos travaux sont garantis. Nous restons disponibles pour l\'entretien et le service après-vente.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  },
];
---

<section class="py-16 md:py-24 lg:py-32 bg-slate-50">
  <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900">Comment ça marche ?</h2>
      <p class="mt-4 text-lg text-slate-600">De votre premier appel à la fin des travaux, en 4 étapes simples.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step) => (
        <div class="relative text-center">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center text-primary-600 mx-auto mb-4">
            <Fragment set:html={step.icon} />
          </div>
          <span class="text-xs font-bold text-primary-500 uppercase tracking-wider">{step.number}</span>
          <h3 class="text-xl font-semibold text-slate-900 mt-1 mb-2">{step.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
