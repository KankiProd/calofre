---
interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Besoin d\'un devis ?',
  text = 'Décrivez votre projet et recevez une estimation gratuite sous 24h. Sans engagement.',
} = Astro.props;
---

<div class="bg-accent-50 border-l-4 border-accent-500 rounded-xl p-6 md:p-8 my-8">
  <h3 class="text-xl font-semibold text-slate-900 mb-2">{title}</h3>
  <p class="text-slate-600 mb-4">{text}</p>
  <a
    href="/devis-gratuit/"
    class="inline-flex items-center gap-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold px-6 py-3 rounded-xl hover:shadow-lg active:scale-95 transition-all"
  >
    Demander un devis gratuit
    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
</div>
